{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm lint)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm fmt.check)",
      "Bash(pnpm fmt.check:*)",
      "Bash(pnpm build.types)",
      "Bash(pnpm build.types:*)",
      "Bash(pnpm fmt)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier --check:*)",
      "Bash(pnpm install)",
      "Bash(pnpm install:*)",
      "Bash(pnpm i)",
      "Bash(pnpm i:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git show)",
      "Bash(git show:*)",
      "Bash(git stash list)",
      "Bash(git remote -v)",
      "Bash(git fetch origin:*)",
      "Bash(git pull origin:*)",
      "Bash(git add:*)",
      "Bash(git restore --staged:*)",
      "Bash(git checkout -b:*)",
      "Bash(git switch:*)",
      "Bash(ls)",
      "Bash(ls:*)",
      "Bash(cat README.md)",
      "Bash(wc -l:*)",
      "Bash(node -v)",
      "Bash(pnpm -v)",
      "Bash(which:*)",
      "Read(//home/user/sportgarden/**)",
      "Glob",
      "Grep"
    ],
    "ask": [
      "Bash(pnpm start)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm build:*)",
      "Bash(pnpm preview)",
      "Bash(pnpm deploy)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(npx tsx seed:*)",
      "Bash(npx tsx seed-:*)",
      "Bash(npx tsx migrate-:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -f:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git checkout main)",
      "Bash(git checkout master)",
      "Bash(git branch -D:*)",
      "Bash(git push origin :*)",
      "Read(//home/user/sportgarden/.env)",
      "Read(//home/user/sportgarden/.env.local)",
      "Read(//home/user/sportgarden/.env.production)",
      "Write(//home/user/sportgarden/.env)",
      "Write(//home/user/sportgarden/.env.local)",
      "Write(//home/user/sportgarden/.env.production)",
      "Edit(//home/user/sportgarden/.env)",
      "Edit(//home/user/sportgarden/.env.local)",
      "Edit(//home/user/sportgarden/.env.production)"
    ],
    "defaultMode": "default"
  },
  "env": {
    "TZ": "America/Argentina/Buenos_Aires"
  }
}
