{
  "crons": [
    {
      "path": "/api/cron/instagram",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/subscriptions",
      "schedule": "0 6 * * 1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)?service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(assets|build)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, s-maxage=31536000, immutable"
        }
      ]
    }
  ]
}
